# Bridge Server 配置模板
# 复制此文件为 ~/.bridge-server/config.yaml 并修改

version: "1.0.0"

# 服务器配置
server:
  host: 127.0.0.1
  port: 19377  # 默认端口：19377
  debug: false
  
  # 🔒 安全：认证 Tokens（必填！）
  # ⚠️  首次启动时会自动生成随机 token，或手动修改为随机字符串
  auth_tokens:
    - "REPLACE_WITH_RANDOM_TOKEN"
  
  # 🔒 安全：CORS 配置
  cors_origins:
    - "http://localhost:3000"
    - "http://localhost:19377"

# 模型提供商配置
providers:
  # 阿里云百炼
  dashscope:
    enabled: true
    provider: dashscope
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    # 🔒 安全：使用环境变量存储 API Key
    api_key_env: DASHSCOPE_API_KEY
    # 或者直接使用（不推荐）：
    # api_key: sk-xxx
    models:
      qwen3.5-flash:
        cost: 0.002  # 元/千 tokens
        use_case: 简单任务
      qwen3.5-plus:
        cost: 0.004
        use_case: 通用任务
      qwen3-max:
        cost: 0.02
        use_case: 复杂推理
      qwen3-coder-plus:
        cost: 0.008
        use_case: 代码生成

  # Moonshot (Kimi)
  moonshot:
    enabled: true
    provider: moonshot
    base_url: https://api.moonshot.cn/v1
    api_key: sk-xxx
    models:
      kimi-chat:
        cost: 0.012
        use_case: 长文本
      kimi-k2.5:
        cost: 0.025
        use_case: 创意写作

  # OpenAI
  openai:
    enabled: false
    provider: openai
    base_url: https://api.openai.com/v1
    api_key: sk-xxx
    models:
      gpt-3.5-turbo:
        cost: 0.002
        use_case: 简单任务
      gpt-4-turbo:
        cost: 0.01
        use_case: 复杂任务
      gpt-4o:
        cost: 0.015
        use_case: 多模态

  # MiniMax
  minimax:
    enabled: false
    provider: minimax
    base_url: https://api.minimax.io/v1
    api_key: xxx
    models:
      MiniMax-M2.5:
        cost: 0.005
        use_case: 通用任务

# 路由策略
routing:
  strategy: balanced  # balanced, cost-first, quality-first, custom
  
  # 自定义模型映射（当 strategy=custom 时使用）
  # 注意：客户端请求时 model 参数只支持 "smart" 这一个值
  #   - model: "smart" → 启用智能场景路由（使用此映射）
  #   - model: 空或不传 → 使用默认策略
  model_mapping:
    simple: qwen3.5-flash      # 简单问候
    coding: qwen3-coder-plus   # 代码任务
    writing: qwen3.5-plus      # 写作
    analysis: qwen3.5-plus     # 分析
    creative: kimi-k2.5        # 创意
    complex: qwen3-max         # 复杂推理
    general: qwen3.5-plus      # 默认

# 预算控制
budget:
  enabled: false
  daily_limit: 50      # 每日预算（元）
  monthly_limit: 1000  # 每月预算（元）
  over_budget_action: downgrade  # downgrade, stop, alert

# 🔒 安全：速率限制配置
rate_limiting:
  enabled: true
  default:
    per_minute: 100
    per_hour: 1000
  endpoints:
    /v1/chat/completions: 60/minute
    /v1/completions: 60/minute
    /health: 10/minute
    /api/usage: 30/minute

# 日志配置
logging:
  level: INFO
  file: /var/log/bridge-server/bridge-server.log
  max_size: 10MB
  backup_count: 5

# 监控配置
metrics:
  enabled: true
  export_prometheus: false
  prometheus_port: 9090

# 旁路模型路由器
# 通过指定的 LLM 对每条请求做动态路由决策，并可压缩过长上下文
bypass_router:
  enabled: false
  # 路由决策模型，格式：provider/model-id，建议使用低成本快速模型
  routing_model: "dashscope/qwen3.5-flash"
  # 自然语言路由规则，将被注入到路由提示词中
  routing_rules: |
    - 代码生成、调试、架构设计任务 → dashscope/qwen3-coder-plus
    - 创意写作、长文本 → moonshot/kimi-chat
    - 其他通用任务 → dashscope/qwen3.5-plus
  # 路由超时（毫秒），超时自动降级到场景路由
  timeout_ms: 3000
  # 消息数超过此阈值时，路由器才被允许建议压缩上下文
  compress_context_threshold: 10
  # 可选：自定义路由提示词（留空使用内置默认值）
  # routing_prompt: ""
  # 可选：自定义上下文压缩提示词（留空使用内置默认值）
  # compress_prompt: ""

# 表达式路由器 (Layer 2 — 安全表达式，无代码执行风险)
# 优先级：bypass_router → expression_router → 自定义 Python 插件 → SmartRouter
# 表达式语法：len/contains/match/starts_with/ends_with/hour/weekday + 比较/逻辑运算
# 完全安全：不调用 Python eval()，通过 AST 白名单验证，无文件/网络访问
expression_router:
  enabled: false
  rules:
    # 编程任务 → 代码模型（高优先级）
    - expr: "match(message, r'代码|编程|函数|debug|bug|algorithm|python|javascript|typescript')"
      model: "dashscope/qwen3-coder-plus"
      reason: "编程任务"
      priority: 20

    # 长文本 + 分析类 → 长上下文模型
    - expr: "len(message) > 2000 and match(message, r'分析|总结|报告|摘要')"
      model: "moonshot/kimi-chat"
      reason: "长文分析"
      priority: 15

    # 夜间低峰期 → 低成本快速模型（22:00 - 08:00）
    - expr: "hour() >= 22 or hour() < 8"
      model: "dashscope/qwen3.5-flash"
      reason: "夜间低成本"
      priority: 5

    # 简短问候 → 极速模型
    - expr: "len(message) < 20 and match(message, r'你好|hi|hello|在吗')"
      model: "dashscope/qwen3.5-flash"
      reason: "简单问候"
      priority: 10

# 场景路由（SmartRouter）兜底，支持 patterns 正则 和 conditions 声明式条件
scenarios:
  # conditions 示例：声明式条件（优先于 patterns，无代码风险）
  # long_document:
  #   enabled: true
  #   priority: 20
  #   conditions:
  #     any_of:
  #       - message_length_gt: 2000
  #       - message_contains: "全文|整篇|长篇"
  #   model: "moonshot/kimi-chat"
  #
  # off_hours_cheap:
  #   priority: 5
  #   conditions:
  #     all_of:
  #       - time_hour_between: [22, 8]    # 跨午夜
  #       - message_length_lt: 500
  #   model: "dashscope/qwen3.5-flash"

