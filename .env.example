# Bridge Server 环境变量配置
# 复制此文件为 ~/.bridge-server/.env 并修改

# =============================================================================
# 🔒 API Keys（从各平台获取）
# =============================================================================
# 阿里云百炼（推荐）：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# Moonshot (Kimi)：https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# OpenAI：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# MiniMax：https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-key-here

# =============================================================================
# 🔒 认证 Token（用于访问 Bridge Server API）
# 生成随机字符串：openssl rand -hex 32
# =============================================================================
AUTH_TOKEN_1=your-very-secret-token-change-this-abc123xyz

# =============================================================================
# 🖥️ 服务器配置
# =============================================================================
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=19377
BRIDGE_DEBUG=false

# =============================================================================
# 📝 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=~/.bridge-server/bridge-server.log

# =============================================================================
# 💰 预算配置（可选）
# =============================================================================
BUDGET_DAILY=50
BUDGET_MONTHLY=1000

# =============================================================================
# ⚡ 速率限制（可选）
# =============================================================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# 🗄️ 数据库配置（可选，默认使用 SQLite）
# =============================================================================
# MySQL: mysql+mysqlconnector://user:pass@localhost:3306/bridge_server
# SQLite: sqlite:///./bridge_server.db
DATABASE_URL=sqlite:///./bridge_server.db

# =============================================================================
# 📊 Redis 配置（可选，用于高并发场景）
# =============================================================================
# redis://localhost:6379
REDIS_URL=redis://localhost:6379
